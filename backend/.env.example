# ============================================================
# ZimCommute Backend – Environment Variables
# ============================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env or any file containing real secrets.

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgres://user:password@localhost:5432/zimcommute

# ------------------------------------------------------------
# SMS Provider – https://sms.localhost.co.zw
# ------------------------------------------------------------
# Required: obtain your API key from the provider dashboard.
# Keep this secret – do not commit it to source control.
SMS_API_KEY=

# Optional overrides (defaults shown):
SMS_API_URL=https://sms.localhost.co.zw/api/v1/sms/send
SMS_SENDER_ID=ZimCommute

# Set to "false" to disable SMS sending entirely (e.g. during local dev).
SMS_ENABLED=true

# Set to "true" to log messages without actually sending them.
SMS_TEST_MODE=false
