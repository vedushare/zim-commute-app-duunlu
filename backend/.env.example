# Backend environment variables
# Copy this file to .env and fill in your values.

# ─────────────────────────────────────────────
# SMS Provider Configuration
# ─────────────────────────────────────────────

# (Required) API key from sms.localhost.co.zw
# Set this on the backend server and restart – it is NEVER stored in the DB.
SMS_API_KEY=

# (Optional) SMS provider endpoint URL
# Default: https://sms.localhost.co.zw/api/v1/sms/send
SMS_API_URL=

# (Optional) Sender name shown on the recipient's handset (max 11 chars)
# Default: ZimCommute
SMS_SENDER_ID=

# (Optional) Set to "false" to disable SMS sending entirely (OTP flow still works)
# Default: true
SMS_ENABLED=

# (Optional) Set to "true" to log SMS messages without actually sending them
# Default: false
SMS_TEST_MODE=
