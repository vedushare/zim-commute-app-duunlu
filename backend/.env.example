# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/zimcommute

# Authentication
JWT_SECRET=your-jwt-secret-here
BETTER_AUTH_SECRET=your-better-auth-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# SMS / OTP Provider
SMS_API_KEY=           # required - your SMS provider API key
SMS_API_URL=https://sms.localhost.co.zw/api/v1/sms/send   # optional
SMS_SENDER_ID=ZimCommute   # optional
SMS_ENABLED=true           # set to false to disable SMS sending
SMS_TEST_MODE=false        # set to true to log OTPs instead of sending

# Server
PORT=3000
NODE_ENV=development
