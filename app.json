{
  "expo": {
    "name": "ZimCommute",
    "slug": "zimcommute",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-vma.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/app-icon-vma.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vedu.sharing",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "ZimCommute needs your location to broadcast your position to passengers and show your ride on the map."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-vma.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vedu.sharing",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ZimCommute needs your location to broadcast your position to passengers.",
          "locationWhenInUsePermission": "ZimCommute needs your location to show your ride on the map."
        }
      ]
    ],
    "scheme": "zimcommute",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://q3k4fsea3tg38xxu8kgvz4h2nvu6gtwh.app.specular.dev"
    }
  }
}